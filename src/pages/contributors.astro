---

<BaseLayout title="Contributors | Lion City Locking Library">
  <section class="page-hero">
    <p class="page-label">Community</p>

    <h1>Contributors</h1>

    <p class="page-description">
      Meet the people who shaped Singapore's Locking scene.
    </p>
  </section>

  {
    generations.map((generation) => (
      <section class="contributor-generation">
        <div class="generation-heading">
          <h2>{generation.title}</h2>
          <p>{generation.description}</p>
        </div>

        <div class="contributor-grid">
          {generation.contributors.map((person) => (
            <article class="contributor-card">
              <img src={person.image} alt={person.name} />

              <div class="contributor-card-content">
                <h3>{person.name}</h3>

                <p class="contributor-meta">{person.affiliation}</p>
                <p class="contributor-status">{person.status}</p>

                {person.quote && <blockquote>"{person.quote}"</blockquote>}

                <a href={`/contributors/${person.name.toLowerCase()}`}>
                  View profile
                </a>

                {person.instagram && (
                  <a href={person.instagram} target="_blank">
                    Instagram
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
