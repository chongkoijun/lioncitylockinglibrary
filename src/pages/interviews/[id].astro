---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const interviews = await getCollection("interviews");

  return interviews.map((interview) => ({
    params: {
      id: interview.id,
    },
    props: {
      interview,
    },
  }));
}

const { interview } = Astro.props;
const { Content } = await render(interview);

const allInterviews = await getCollection("interviews");

const relatedInterviews = allInterviews
  .filter((otherInterview) => {
    if (otherInterview.id === interview.id) return false;

    return otherInterview.data.topics?.some((topic) =>
      interview.data.topics?.includes(topic),
    );
  })
  .slice(0, 3);
---

<BaseLayout title={`${interview.data.title} | Lion City Locking Library`}>
  <article class="prose">
    <header class="interview-header">
      <p class="page-label">Lock Talk</p>

      <h1>{interview.data.title}</h1>

      <p class="interview-date">
        Recorded: {interview.data.recorded_date}
      </p>

      <p class="interview-contributor">
        Featuring{" "}
        <a href={`/contributors/${interview.data.interviewee.toLowerCase()}`}>
          {interview.data.interviewee}
        </a>
      </p>
    </header>

    <Content />

    {
      interview.data.topics?.length > 0 && (
        <section class="interview-topics">
          <h2>Topics</h2>

          <ul>
            {interview.data.topics.map((topic) => (
              <li>
                <a href={`/topics/${topic.toLowerCase()}`}>{topic}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      relatedInterviews.length > 0 && (
        <section class="related-interviews">
          <h2>Related Articles</h2>

          <div class="related-interviews-grid">
            {relatedInterviews.map((related) => (
              <a
                class="related-interview-card"
                href={`/interviews/${related.id}`}
              >
                <h3>{related.data.title}</h3>

                <p class="related-interview-date">
                  {related.data.recorded_date}
                </p>

                <p>{related.data.summary}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
