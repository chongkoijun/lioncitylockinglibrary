---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Ask Anything | Lion City Locking Library">
  <section class="page-hero">
    <p class="page-label">Community</p>

    <h1>Ask Anything</h1>

    <p class="page-description">
      A space for the Singapore Locking community to ask questions, share
      knowledge, discuss history, and document stories together.
    </p>
  </section>
  <div class="ask-page">
    <div class="ask-grid">
      <section class="ask-section">
        <h2>What belongs here?</h2>

        <ul>
          <li>Questions about Singapore Locking history</li>
          <li>Questions on technique and culture</li>
          <li>Stories from different generations of dancers</li>
        </ul>
      </section>

      <section class="ask-section">
        <h2>Community Guidelines</h2>

        <ul>
          <li>Be respectful and inclusive</li>
          <li>Different memories and perspectives may coexist</li>
          <li>Credit original sources whenever possible</li>
          <li>Keep discussions constructive</li>
        </ul>
      </section>
    </div>

    <section class="ask-section">
      <h2>Discussion Board</h2>

      <p>Community discussion integration coming soon.</p>
    </section>
  </div>
</BaseLayout>
