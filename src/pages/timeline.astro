---
import BaseLayout from "../layouts/BaseLayout.astro";
import { eras } from "../data/timeline";
---

<BaseLayout title="Timeline | Lion City Locking Library">
  <section class="page-hero">
    <p class="page-label">History</p>

    <h1>Timeline</h1>

    <p class="page-description">
      A chronological archive of key events, crews, battles, workshops, and
      milestones in Singapore's Locking history.
    </p>
  </section>

  {
    eras.map((era) => (
      <section class="timeline-era">
        <h2>{era.title}</h2>

        <div class="timeline">
          {era.entries.map((entry) => (
            <article class="timeline-entry">
              <div class="timeline-year">{entry.year}</div>

              <div class="timeline-marker" />

              <div class="timeline-content">
                <h3>{entry.title}</h3>

                {entry.points.length > 0 && (
                  <ul>
                    {entry.points.map((point) => (
                      <li>{point}</li>
                    ))}
                  </ul>
                )}

                {entry.contributors?.length > 0 && (
                  <div class="timeline-related">
                    <p>Related contributors</p>

                    <ul>
                      {entry.contributors.map((person) => (
                        <li>
                          <a href={`/contributors/${person}`}>
                            {person.replace(/-/g, " ")}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
